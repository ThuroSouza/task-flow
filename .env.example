# Clean Supabase project only.
# Do not use the Lovable/original database credentials here.
# Copy this file to .env.local and replace the placeholder values before running locally.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=SUA_ANON_PUBLIC_KEY

# OAuth Google fica desligado na copia limpa ate ser configurado no Supabase novo.
VITE_ENABLE_GOOGLE_AUTH=false

# Optional fallback names used by older server/dev code paths.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=SUA_ANON_PUBLIC_KEY

# Required only for server-side/admin operations.
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY
